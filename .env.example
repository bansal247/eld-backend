# Django
SECRET_KEY=replace-with-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenRouteService — get a free key at https://openrouteservice.org/dev/
# Free tier allows 2,000 directions requests/day.
# Without a key, the app falls back to a great-circle distance estimate
# (acceptable for testing but not realistic for actual road trips).
ORS_API_KEY=

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database — leave blank to use SQLite (default for dev)
# DATABASE_URL=postgres://user:pass@localhost:5432/eld_planner
